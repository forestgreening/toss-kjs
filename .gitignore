# OMC runtime/session state (transient, not project content)
.omc/state/
.omc/logs/
.omc/notepad.md
.omc/project-memory.json
.omc/research/

# Node
node_modules/
dist/
*.log

# 앱인토스 번들 빌드 산출물/캐시 (ait build) — 저장소에 미포함
*.ait
.granite/

# 클라우드 백업 참조 서버의 로컬 데이터(암호문) — 저장소에 미포함
server/.data/

# 디자인 소스(목업 zip 등) — 저장소에 미포함
*.zip
# 디자인 zip에서 추출된 중간 export(최종본은 assets/logo, assets/screenshots) — 미포함
assets/a/
assets/깃허브 프로젝트 디자인/
# 스크린샷 캡처 중 잘못 생성된 OMC 상태 누수 방지
assets/**/.omc/

